# Shared secret between the web app and this API (any long random string).
# Generate: openssl rand -hex 32
API_SECRET_TOKEN=

# Google Drive OAuth (run get_refresh_token.py locally to obtain these)
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxx
GOOGLE_REFRESH_TOKEN=1//0xxxxx

# Optional: Drive folder ID to upload into. Empty = root "My Drive".
GOOGLE_DRIVE_FOLDER_ID=

# Optional: comma-separated origins allowed for CORS. Default "*".
# Example: https://your-app.lovable.app
ALLOWED_ORIGINS=*

# Optional: cookies.txt (Netscape format) for sites needing login.
YT_DLP_COOKIES=
