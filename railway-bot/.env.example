# Telegram bot token from @BotFather
BOT_TOKEN=123456:ABC-your-telegram-bot-token

# Optional: comma-separated Telegram user IDs allowed to use the bot.
# Empty = everyone allowed. Get your ID from @userinfobot.
ALLOWED_USER_IDS=

# Google Drive OAuth (run get_refresh_token.py locally to obtain these)
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxx
GOOGLE_REFRESH_TOKEN=1//0xxxxx

# Optional: Drive folder ID to upload into. Empty = root "My Drive".
# Get from folder URL: https://drive.google.com/drive/folders/<THIS_ID>
GOOGLE_DRIVE_FOLDER_ID=

# Optional: cookies.txt content for sites that need login (Netscape format).
# Paste the whole file content as one env var value.
YT_DLP_COOKIES=
